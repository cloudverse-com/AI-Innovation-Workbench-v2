# ============================================================
# AI Innovation Workbench - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.

# --- Azure AI Foundry Connection ---
# Find this in Azure AI Foundry > Your Project > Overview > Project endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# Your Azure AI Foundry API key (not az login - just the key)
# Find this in Azure AI Foundry > Your Project > Settings > API keys
FOUNDRY_API_KEY=your-azure-ai-foundry-api-key-here

# --- Model Configuration ---
# The model to use by default in all demos
DEFAULT_MODEL=gpt-5

# Comma-separated list of models to show in the frontend dropdown
# These must be deployed in your Azure AI Foundry project
AVAILABLE_MODELS=gpt-5,gpt-5.4

# --- System Prompts ---
# Format: "Name::Prompt text||Name2::Prompt text2"
# The frontend shows these as a dropdown; the selected prompt is sent with each request
SYSTEM_PROMPTS=General Assistant::You are a helpful, friendly assistant.||Technical Expert::You are a technical expert who provides detailed, accurate explanations.||Code Reviewer::You review code for best practices, bugs, and improvements. Be specific and constructive.||Creative Writer::You are a creative writing assistant who helps with storytelling and content creation.

# --- Security ---
# The API key the frontend must send in the X-API-Key header for every request
# Change this to a strong random value in production
DEMO_API_KEY=demo-key-12345

# --- Azure Content Understanding (Demo 06) ---
# Base endpoint of your Azure AI resource (same host as above, without the /api/projects/... path)
# Example: https://your-resource.services.ai.azure.com/
CONTENT_UNDERSTANDING_ENDPOINT=https://<your-resource>.services.ai.azure.com/
# Comma-separated analyzer IDs created in your Content Understanding resource
# Example: CONTENT_UNDERSTANDING_ANALYZER_IDS=patient_medical_report,invoice_analyzer,receipt_analyzer
CONTENT_UNDERSTANDING_ANALYZER_IDS=patient_medical_report

# --- Azure OpenAI Embeddings (Demo 11 — In-Memory Vector Store) ---
# Azure OpenAI resource endpoint (the openai.azure.com host, NOT the Foundry project URL)
# Example: https://<your-resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# API key for that Azure OpenAI resource
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
# Deployment name of your embedding model
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# Vector dimensions: 1536 for text-embedding-3-small / ada-002, 3072 for text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
# Azure OpenAI REST API version
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Azure AI Search grounding (Demo 12 — Agent grounded with AI Search) ---
# Full Foundry PROJECT CONNECTION ID for your Azure AI Search connection — NOT the
# search service resource ID. Create the connection in the Foundry portal
# (Management center > Connections > Add connection > Azure AI Search), then copy
# its connection ID. Format:
# /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<foundry>/projects/<proj>/connections/<name>
AZURE_AI_SEARCH_CONNECTION_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<foundry>/projects/<proj>/connections/<name>
# The index name inside the connected Azure AI Search resource
AZURE_AI_SEARCH_INDEX=your-index-name
# Retrieval mode: simple | semantic | vector | vector_simple_hybrid | vector_semantic_hybrid
# "simple" works on any index; vector_semantic_hybrid needs vector fields + a semantic config.
AZURE_AI_SEARCH_QUERY_TYPE=simple
# Number of results retrieved per query
AZURE_AI_SEARCH_TOP_K=5

# --- Server ---
PORT=8000
